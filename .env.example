# =============================================================================
# TRPM-LIMS environment configuration
# Copy to `.env` for local dev, or supply via your secret manager in production.
# NEVER commit a real .env to version control.
# =============================================================================

# ----- Core ------------------------------------------------------------------
# Generate a strong key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-me-with-a-50+-char-random-string
DEBUG=False
ALLOWED_HOSTS=lims.example.org,api.lims.example.org

# ----- Database --------------------------------------------------------------
# PostgreSQL DSN. For local dev you can omit this and SQLite will be used.
# DATABASE_URL=postgres://lims_user:lims_pass@localhost:5432/trpm_lims

# ----- HTTPS / cookies (only enforced when DEBUG=False) ----------------------
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
CSRF_TRUSTED_ORIGINS=https://lims.example.org,https://api.lims.example.org

# ----- CORS ------------------------------------------------------------------
# Comma-separated list of allowed origins for browser clients.
CORS_ALLOWED_ORIGINS=https://lims.example.org
CORS_ALLOW_ALL_ORIGINS=False

# ----- Celery / Redis --------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ----- Email -----------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.org
EMAIL_PORT=587
EMAIL_HOST_USER=lims@example.org
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@lims.example.org

# ----- Sentry (optional) -----------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0

# ----- Lab branding ----------------------------------------------------------
LAB_NAME=Translational Research and Precision Medicine Lab
LAB_ADDRESS=
LAB_PHONE=
LAB_ACCREDITATION=

# ----- External integrations -------------------------------------------------
NCBI_API_KEY=
NCBI_EMAIL=admin@trpm-lims.org
FHIR_BASE_URL=http://localhost:8000/fhir

# ----- Compliance feature flags ----------------------------------------------
# ENABLE_PART11: enforce 21 CFR Part 11 electronic signatures on result
#   approval / release workflows. Required for clinical (CAP/CLIA) labs.
# ENABLE_HIPAA_MODE: enable PHI masking, stricter session timeouts, and
#   audit-trail hardening required for HIPAA-covered deployments.
ENABLE_PART11=False
ENABLE_HIPAA_MODE=False

# Password aging — force change every N days (0 disables).
PASSWORD_MAX_AGE_DAYS=90
